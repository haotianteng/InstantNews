# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///data/news_terminal.db
# DATABASE_URL=postgresql://signal:signal@localhost:5432/signal_news

# Server
PORT=8000
STALE_SECONDS=30
FETCH_TIMEOUT=5

# Deduplication
DEDUP_THRESHOLD=0.85

# Data retention (days, default 5 years)
MAX_AGE_DAYS=1825

# Background worker interval (seconds)
WORKER_INTERVAL_SECONDS=30

# Firebase Auth
# FIREBASE_CREDENTIALS=/path/to/serviceAccountKey.json
# FIREBASE_CREDENTIALS_JSON='{"type":"service_account",...}'

# Stripe (leave empty until account is registered)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_MAX=
